{
  "manifest_version": 3,
  "name": "Agent Bridge",
  "version": "1.0.0",
  "description": "Conecta seu app web ao Claude Code local via Native Messaging",

  "permissions": [
    "nativeMessaging",
    "tabs"
  ],

  "host_permissions": [
    "https://seuapp.com/*",
    "http://localhost/*"
  ],

  "background": {
    "service_worker": "src/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://seuapp.com/*", "http://localhost/*"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Agent Bridge",
    "default_icon": "icons/icon48.png"
  }
}
