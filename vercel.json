{
  "rewrites": [
    { "source": "/((?!api|_next|favicon|logo|icons|manifest|sw|landing-).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
