{
  "manifest_version": 3,
  "name": "Ads Optimizer Pro",
  "version": "1.0.0",
  "description": "Otimização inteligente de campanhas Meta Ads direto no Ads Manager",
  "permissions": ["storage", "tabs", "sidePanel", "alarms"],
  "host_permissions": [
    "https://graph.facebook.com/*",
    "https://www.facebook.com/*",
    "https://facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Ads Optimizer Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
